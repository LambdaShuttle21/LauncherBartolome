<UserControl x:Class="LauncherBartolome.Views.AplicacionesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="30">

            <Border Background="#1C1C1C"
        CornerRadius="10"
        Padding="15"
        Margin="0,0,0,20">

                <TextBlock Text="Aplicaciones"
               Foreground="White"
               FontSize="22"
               FontWeight="SemiBold"/>
            </Border>

            <Border Background="#1C1C1C"
                    CornerRadius="14"
                    Padding="16"
                    Margin="0,0,0,15"
                    BorderBrush="#222"
                    BorderThickness="1">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="240"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="140"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" CornerRadius="10" ClipToBounds="True" Margin="0,0,14,0">
                        <Image Source="{Binding CurrentBannerImage}"
                               Height="100"
                               Stretch="UniformToFill"/>
                    </Border>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="{Binding CurrentBannerTitle}"
                                   Foreground="White"
                                   FontSize="18"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding CurrentBannerSubtitle}"
                                   Foreground="#BDBDBD"
                                   FontSize="13"
                                   TextWrapping="Wrap"
                                   Margin="0,6,0,0"/>
                    </StackPanel>

                    <Button Grid.Column="2"
                            Content="Ver mas"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Height="34"
                            VerticalAlignment="Center"
                            Command="{Binding OpenBannerLinkCommand}"/>
                </Grid>
            </Border>

            <Border Background="#1C1C1C"
        CornerRadius="10"
        Padding="10"
        Margin="0,0,0,15"
        BorderBrush="#222"
        BorderThickness="1">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="28"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Lupa -->
                    <TextBlock Text="🔍"
                   FontSize="14"
                   VerticalAlignment="Center"
                   Foreground="#AAAAAA"
                   Margin="2,0,0,0"/>

                    <!-- Input + placeholder -->
                    <Grid Grid.Column="1">
                        <TextBox x:Name="SearchBox"
                     Height="34"
                     VerticalContentAlignment="Center"
                     Foreground="White"
                     Background="#2A2A2A"
                     BorderBrush="#333"
                     TextChanged="SearchBox_TextChanged"
                     Padding="10,0"
                     KeyDown="SearchBox_KeyDown"/>

                        <TextBlock Text="Buscar aplicaciones..."
                       Foreground="#888888"
                       Margin="14,0,0,0"
                       VerticalAlignment="Center"
                       IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ElementName=SearchBox, Path=Text.Length}" Value="0">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Grid>
            </Border>

            <Grid>
                <ItemsControl x:Name="AppsItems" ItemsSource="{Binding Apps}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource LauncherCardStyle}">
                                <Grid Margin="20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="120"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Orientation="Vertical" VerticalAlignment="Center">

                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Image Source="{Binding Icon}"
                                       Width="32"
                                       Height="32"
                                       Margin="0,0,12,0"/>

                                            <TextBlock Text="{Binding Name}"
                                           Foreground="White"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <TextBlock Text="{Binding ExecutablePath}"
                                       Visibility="Collapsed"/>
                                    </StackPanel>

                                    <Button Grid.Column="1"
                                Content="Abrir"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Height="32"
                                Margin="10,0,0,0"
                                Command="{Binding DataContext.OpenAppCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="{Binding}"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="No hay resultados para tu búsqueda."
               Foreground="#AAAAAA"
               FontSize="13"
               TextAlignment="Center"
               VerticalAlignment="Center"
               HorizontalAlignment="Center"
               Margin="20"
               IsHitTestVisible="False">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ElementName=AppsItems, Path=Items.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>

        </StackPanel>
    </ScrollViewer>

</UserControl>

