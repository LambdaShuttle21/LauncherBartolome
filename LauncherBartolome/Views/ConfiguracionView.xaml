<UserControl x:Class="LauncherBartolome.Views.ConfiguracionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#0F0F0F">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- TopBar -->
        <Border Grid.Row="0"
        Background="#1C1C1C"
        CornerRadius="10"
        Padding="15"
        Margin="0,0,0,20">
            <TextBlock Text="Panel Técnico"
               Foreground="White"
               FontSize="22"
               FontWeight="SemiBold"/>
        </Border>

        <!-- Formulario añadir -->
        <Border Grid.Row="1"
        Background="#202020"
        BorderBrush="#333"
        BorderThickness="1"
        CornerRadius="6"
        Padding="12"
        Margin="0,0,0,15">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="110"/>
                </Grid.ColumnDefinitions>

                <!-- Labels -->
                <TextBlock Grid.Row="0"
                   Grid.Column="0"
                   Text="Nombre"
                   Foreground="#CCCCCC"
                   Margin="2,0,0,6"/>

                <TextBlock Grid.Row="0"
                   Grid.Column="1"
                   Text="Ruta ejecutable (.exe)"
                   Foreground="#CCCCCC"
                   Margin="2,0,0,6"/>

                <!-- Inputs + botones -->
                <TextBox Grid.Row="1"
                 Grid.Column="0"
                 x:Name="NameBox"
                 Height="30"
                 Margin="0,0,10,0"
                 VerticalContentAlignment="Center"
                 Foreground="White"
                 Background="#2A2A2A"
                 BorderBrush="#333"/>

                <TextBox Grid.Row="1"
                 Grid.Column="1"
                 x:Name="PathBox"
                 Height="30"
                 Margin="0,0,10,0"
                 VerticalContentAlignment="Center"
                 Foreground="White"
                 Background="#2A2A2A"
                 BorderBrush="#333"/>

                <Button Grid.Row="1"
                    Grid.Column="2"
        Content="Examinar..."
        Height="30"
        Margin="0,0,10,0"
        Style="{StaticResource PrimaryButtonStyle}"
        Click="Browse_Click" Cursor="Hand"/>

                <Button Grid.Row="1"
                Grid.Column="3"
                Content="Añadir"
                Height="30"
                Margin="0,0,10,0"
                Click="Add_Click"/>

                <Button Grid.Row="1"
                Grid.Column="4"
                Content="Eliminar"
                Height="30"
                Click="Delete_Click"/>
            </Grid>
        </Border>

        <!-- DataGrid -->
        <!-- DataGrid + Resources -->
        <Border Grid.Row="2"
        Background="#1E1E1E"
        BorderBrush="#333"
        BorderThickness="1"
        CornerRadius="10"
        Padding="8">

            <Grid>
                <!-- DataGrid -->
                <DataGrid x:Name="AppsGrid"
                  ItemsSource="{Binding Apps}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  Background="Transparent"
                  Foreground="White"
                  RowBackground="Transparent"
                  AlternatingRowBackground="#252525"
                  GridLinesVisibility="None"
                  BorderThickness="0"
                  HeadersVisibility="Column"
                  SelectionUnit="FullRow"
                  SelectionMode="Single">

                    <DataGrid.Resources>

                        <!-- CELDAS -->
                        <Style TargetType="DataGridCell">
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding" Value="10,6"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#2E5AA7"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>

                        <!-- FILAS -->
                        <Style TargetType="DataGridRow">
                            <Setter Property="MinHeight" Value="34"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Style.Triggers>
                                <Trigger Property="AlternationIndex" Value="1">
                                    <Setter Property="Background" Value="#252525"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#2E5AA7"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#2A2A2A"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>

                        <!-- HEADERS -->
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="Background" Value="#2A2A2A"/>
                            <Setter Property="BorderBrush" Value="#333"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="Padding" Value="10,8"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                        </Style>

                    </DataGrid.Resources>
                    <!--  Columns  -->
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Nombre"
                    Binding="{Binding Name}"
                    Width="200"/>

                        <DataGridTextColumn Header="Ruta Ejecutable"
                    Binding="{Binding ExecutablePath}"
                    Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Placeholder -->
                <TextBlock Text="No hay aplicaciones configuradas. Añade una arriba y guarda cambios."
Foreground="#AAAAAA"
FontSize="13"
TextAlignment="Center"
VerticalAlignment="Center"
HorizontalAlignment="Center"
Margin="20"
IsHitTestVisible="False">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ElementName=AppsGrid, Path=Items.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
        </Border>

        <!-- Botón guardar -->
        <Button Grid.Row="3"
        Content="Guardar Cambios"
        Style="{StaticResource PrimaryButtonStyle}"
        Height="35"
        Width="160"
        HorizontalAlignment="Right"
        Margin="0,20,0,0"
        Click="Guardar_Click"/>
    </Grid>
</UserControl>

