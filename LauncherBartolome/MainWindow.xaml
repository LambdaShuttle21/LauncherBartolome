<Window x:Class="LauncherBartolome.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LauncherBartolome"
        mc:Ignorable="d"
        Title="MainWindow"
        Height="720"
        Width="1280"
        WindowStartupLocation="CenterScreen">

    <Window.Background>
        <SolidColorBrush Color="#0F0F0F"/>
    </Window.Background>

    <Window.Resources>

        <!-- Estilo botón activo -->
        <Style x:Key="SidebarButtonActiveStyle"
               TargetType="Button"
               BasedOn="{StaticResource SidebarButtonStyle}">
            <Setter Property="Background" Value="#1E1E1E"/>
        </Style>

    </Window.Resources>

    <!-- GRID -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="40"/>
            
        </Grid.RowDefinitions>

        <!--SIDEBAR IZQUIERDA [0,0]-->
        <Border Grid.Column="0"
        Grid.Row="0"
        Background="#121212">
            <StackPanel>

                <!-- Logo / título -->
                <Border Margin="12,18,12,14"
        Padding="10"
        Background="#101010"
        CornerRadius="10"
        BorderBrush="#1F1F1F"
        BorderThickness="1">

                    <Button Click="Logo_Click"
        Background="Transparent"
        BorderBrush="{x:Null}"
        BorderThickness="0"
        Padding="0"
        Cursor="Hand">

                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <ContentPresenter/>
                            </ControlTemplate>
                        </Button.Template>

                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Opacity" Value="0.9"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Opacity" Value="1"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>

                        <Image Source="/Assets/Bartolome_Logo_Transparent.png"
           Height="56"
           Stretch="Uniform"
           HorizontalAlignment="Center"
           RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Button>
                </Border>

                <Border Height="1"
        Background="#1F1F1F"
        Margin="12,0,12,16"/>

                <!-- Menú -->

                <Button x:Name="BtnApps"
        Content="Aplicaciones"
        Style="{StaticResource SidebarButtonStyle}"
        Click="Aplicaciones_Click"/>

                <Button x:Name="BtnConfig"
        Content="Configuración"
        Style="{StaticResource SidebarButtonStyle}"
        Click="Configuracion_Click"/>

                <Button x:Name="BtnTaskMgr"
        Style="{StaticResource SidebarButtonStyle}"
        Click="TaskMgr_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE7EF;" Margin="0,0,10,0"/>
                        <TextBlock Text="Administrador de tareas"/>
                    </StackPanel>
                </Button>

                <Button x:Name="BtnControlPanel"
        Style="{StaticResource SidebarButtonStyle}"
        Click="ControlPanel_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE713;" Margin="0,0,10,0"/>
                        <TextBlock Text="Panel de control"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <!--MAIN GRID [0,1]-->
        <Border Grid.Column="1"
        Grid.Row="0"
        Margin="20"
        CornerRadius="14"
        BorderBrush="#222"
        BorderThickness="1">

            <!-- ClipToBounds para que el fondo no "se salga" con el CornerRadius -->
            <Grid ClipToBounds="True">

                <!-- Fondo con diagonales -->
                <Border CornerRadius="14">
                    <Border.Background>
                        <DrawingBrush Stretch="UniformToFill">
                            <DrawingBrush.Drawing>
                                <DrawingGroup>

                                    <!-- Base: degradado suave -->
                                    <GeometryDrawing>
                                        <GeometryDrawing.Brush>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#0B0B0B" Offset="0"/>
                                                <GradientStop Color="#121212" Offset="0.55"/>
                                                <GradientStop Color="#0A0A0A" Offset="1"/>
                                            </LinearGradientBrush>
                                        </GeometryDrawing.Brush>
                                        <GeometryDrawing.Geometry>
                                            <RectangleGeometry Rect="0,0,1000,600"/>
                                        </GeometryDrawing.Geometry>
                                    </GeometryDrawing>

                                    <!-- Diagonales -->
                                    <GeometryDrawing Brush="#14FFFFFF">
                                        <GeometryDrawing.Geometry>
                                            <PathGeometry Figures="M720,0 L1000,0 L1000,220 Z"/>
                                        </GeometryDrawing.Geometry>
                                    </GeometryDrawing>

                                    <GeometryDrawing Brush="#0CFFFFFF">
                                        <GeometryDrawing.Geometry>
                                            <PathGeometry Figures="M650,0 L730,0 L1000,210 L1000,290 Z"/>
                                        </GeometryDrawing.Geometry>
                                    </GeometryDrawing>

                                    <GeometryDrawing Brush="#10FFFFFF">
                                        <GeometryDrawing.Geometry>
                                            <PathGeometry Figures="M0,420 L0,600 L320,600 Z"/>
                                        </GeometryDrawing.Geometry>
                                    </GeometryDrawing>

                                    <GeometryDrawing Brush="#0AFFFFFF">
                                        <GeometryDrawing.Geometry>
                                            <PathGeometry Figures="M0,360 L0,420 L360,600 L300,600 Z"/>
                                        </GeometryDrawing.Geometry>
                                    </GeometryDrawing>

                                    <!-- Viñeta -->
                                    <GeometryDrawing>
                                        <GeometryDrawing.Brush>
                                            <RadialGradientBrush Center="0.5,0.5"
                                                         GradientOrigin="0.5,0.5"
                                                         RadiusX="0.75" RadiusY="0.75">
                                                <GradientStop Color="#00FFFFFF" Offset="0"/>
                                                <GradientStop Color="#22000000" Offset="1"/>
                                            </RadialGradientBrush>
                                        </GeometryDrawing.Brush>
                                        <GeometryDrawing.Geometry>
                                            <RectangleGeometry Rect="0,0,1000,600"/>
                                        </GeometryDrawing.Geometry>
                                    </GeometryDrawing>

                                </DrawingGroup>
                            </DrawingBrush.Drawing>
                        </DrawingBrush>
                    </Border.Background>
                </Border>

                <!-- Capa de "glass" encima para que el contenido no pierda legibilidad -->
                <Border Background="#66161616" CornerRadius="14"/>

                <!-- Contenido real -->
                <Grid Margin="15">
                    <ContentControl x:Name="MainContent" Opacity="1"/>
                </Grid>

            </Grid>
        </Border>
        <!--FOOTER-->
        <Border 
        Grid.ColumnSpan="2"
        Grid.Row="1"
        Background="#0E0E0E">
            <TextBlock Text="Bartolomé Consultores | v1.0"
               Foreground="Gray"
               VerticalAlignment="Center"
               Margin="15,0"/>
        </Border>

    </Grid>
</Window>
